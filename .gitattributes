# =============================================================================
# .gitattributes – Zeilenenden und Binärdateien korrekt behandeln
#
# Verhindert CRLF/LF-Probleme zwischen Windows und Linux.
# =============================================================================

# Standard: Git entscheidet automatisch
* text=auto

# Shell-Skripte: immer LF (Unix-Zeilenenden)
*.sh text eol=lf

# Batch-Dateien: immer CRLF (Windows-Zeilenenden)
*.bat text eol=crlf
*.cmd text eol=crlf

# PowerShell: CRLF
*.ps1 text eol=crlf

# Python: LF (funktioniert auf beiden Plattformen)
*.py text eol=lf

# Konfigurationsdateien: LF
*.txt text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf

# Binärdateien: nicht anfassen
*.pkl binary
*.joblib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.zip binary
*.tar.gz binary
*.gz binary
*.ex5 binary
*.ex4 binary
*.mqh binary
