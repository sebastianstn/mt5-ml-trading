[MASTER]
ignore=__pycache__,.venv

[MESSAGES CONTROL]
# Projektweit vorerst deaktiviert, da viele Python-Skripte als CLI/Analyse-Tools gebaut sind.
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    invalid-name,
    too-many-lines,
    too-many-return-statements,
    too-many-locals,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-statements,
    import-outside-toplevel

[FORMAT]
# Einheitliche Zeilenlänge für dieses Projekt.
max-line-length=140

[LOGGING]
# Erzwingt logger.info("... %s", wert) statt f-strings im Logging.
logging-format-style=old
